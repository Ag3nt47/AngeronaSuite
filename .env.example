# ── Angerona environment template ───────────────────────────────────────────
# Copy this file to ".env" and fill in real values.
# ".env" is git-ignored and must NEVER be committed.

# --- AI providers (optional; only needed for cloud escalation) ---
ANTHROPIC_API_KEY=
GEMINI_API_KEYS=
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_API_KEY=

# --- Storage / data root ---
# Point this at a non-system volume (e.g. F:\...) to keep logs/caches off C:.
ANGERONA_DATA=
ANGERONA_STORAGE_AUTOMIGRATE=0

# --- Decoupled resilience ecosystem (standalone scanner/watchdog) ---
ANGERONA_RESILIENCE=0

# --- SIEM forwarder (optional) ---
ANGERONA_SIEM_HOST=
ANGERONA_SIEM_PORT=514
ANGERONA_SIEM_PROTO=udp
ANGERONA_SIEM_MINSEV=MEDIUM

# --- Threat-intel IOC feed (optional STIX/TAXII or JSON URL) ---
ANGERONA_IOC_FEED=

# --- Mobile alerting (optional) ---
ANGERONA_MOBILE_HOST=
ANGERONA_MOBILE_OPERATOR=
ANGERONA_MOBILE_PIN=
ANGERONA_MOBILE_NOTIFY_WINDOW=00:00-24:00
